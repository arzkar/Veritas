# =============================================================================
# Veritas — Root .gitignore
# Python (FastAPI backend) + Next.js (frontend) + Docker + tooling
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/
.env/

# pyenv
.python-version

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# Testing & coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/

# Type checkers
.mypy_cache/
.pyre/
.pyright/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Logs
*.log
pip-log.txt
pip-delete-this-directory.txt

# -----------------------------------------------------------------------------
# Next.js / Node (frontend handled by frontend/.gitignore too)
# -----------------------------------------------------------------------------
node_modules/
.next/
/out/
/build/
*.tsbuildinfo

# Package manager debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Yarn v2+
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnp.*

# Vercel
.vercel

# -----------------------------------------------------------------------------
# Environment & secrets — NEVER commit these
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.p12

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Local data volumes (mounted via docker-compose)
data/postgres/
data/pgdata/

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# -----------------------------------------------------------------------------
# Linux
# -----------------------------------------------------------------------------
*~
.fuse_hidden*
.directory
.Trash-*

# -----------------------------------------------------------------------------
# Windows
# -----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# IDEs & editors
# -----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*.swn
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.orig
data/